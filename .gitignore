


# =============================================================================
# .gitignore - ALPHAOpt Parser API
# =============================================================================

# -----------------------------------------------------------------------------
# ENTORNO 
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# Sí subir:
# .env.example  ← template sin valores reales

# -----------------------------------------------------------------------------
# CREDENCIALES GCS 
# -----------------------------------------------------------------------------
*.json
!package.json
secrets/

# -----------------------------------------------------------------------------
# TEMP 
# -----------------------------------------------------------------------------
/tmp/
temp/

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
.Python
*.egg-info/
dist/
build/
venv/
env/
.venv
.venv/

# -----------------------------------------------------------------------------
# TESTING
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
docs/

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
*.log
logs/
docker_test_logs.txt

# -----------------------------------------------------------------------------
# STORAGE (arquitectura anterior — eliminada)
# -----------------------------------------------------------------------------
storage/